---
// AppleLoader.astro
---

<div
  id="apple-loader"
  class="fixed inset-0 z-[10000] flex flex-col items-center justify-center overflow-hidden bg-black transition-opacity duration-1000"
  aria-live="polite"
  role="status"
>
  <!-- Particles Background -->
  <div class="absolute inset-0 overflow-hidden" id="particles-container">
    <!-- Particles will be injected by JS -->
  </div>

  <div class="flex flex-col items-center justify-center w-full z-10">
    <!-- Apple Logo with Bootup Animation -->
    <div id="apple-logo-container" class="mb-16 opacity-0 scale-50 transition-all duration-1500" style="transition-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);">
      <div class="relative flex items-center justify-center logo-glow">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-20 h-20 text-white fill-current drop-shadow-2xl logo-pulse">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <!-- Pulsing Ring -->
        <div class="absolute rounded-full border border-white/20 ring-pulse" style="width: 120px; height: 120px; left: -20px; top: -20px;"></div>
      </div>
    </div>

    <!-- Bootup Progress Section -->
    <div id="loader-content-container" class="text-center max-w-md w-full px-8 opacity-0 translate-y-[30px] transition-all duration-1000">
      <!-- Progress Bar -->
      <div class="w-full h-1 bg-white/10 rounded-full overflow-hidden mb-6">
        <div id="loader-progress-bar" class="h-full bg-gradient-to-r from-white via-gray-300 to-white rounded-full transition-all duration-300 ease-out" style="width: 0%; box-shadow: 0 0 10px rgba(255,255,255,0.5);"></div>
      </div>
      
      <!-- Loading Text -->
      <p id="loader-text" class="text-white/70 text-sm mb-2 transition-opacity duration-500" style="font-family: 'SF Pro Text', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;">Starting up...</p>

      <!-- Progress Percentage -->
      <p id="loader-percentage" class="text-white/50 text-xs" style="font-family: 'SF Pro Text', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;">0%</p>
    </div>

  </div>

  <!-- Completion overlay -->
  <div id="completion-overlay" class="absolute inset-0 bg-black z-[200] opacity-0 pointer-events-none transition-opacity duration-800 ease-in-out"></div>
</div>

<style>
  .logo-glow {
    animation: glowPulse 3s ease-in-out infinite;
  }
  @keyframes glowPulse {
    0%, 100% { filter: drop-shadow(0 0 20px rgba(255,255,255,0.3)); }
    50% { filter: drop-shadow(0 0 40px rgba(255,255,255,0.6)); }
  }

  .logo-pulse {
    animation: svgPulse 4s ease-in-out infinite;
  }
  @keyframes svgPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  .ring-pulse {
    animation: ringAnim 3s ease-in-out infinite;
  }
  @keyframes ringAnim {
    0%, 100% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.3); opacity: 0.1; }
  }

  .shimmer-anim {
    animation: shimmer 5s ease-in-out infinite;
    transform: translateX(-100%);
  }
  @keyframes shimmer {
    0%, 40% { transform: translateX(-100%); }
    60%, 100% { transform: translateX(100%); }
  }

  .arrow-anim {
    display: inline-block;
    animation: arrowMove 1.5s ease-in-out infinite;
  }
  @keyframes arrowMove {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(4px); }
  }

  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    background-color: rgba(255,255,255,0.03);
    border-radius: 50%;
    animation: particleFloat infinite ease-in-out;
  }
  @keyframes particleFloat {
    0% {
      transform: translateY(-30px) scale(0);
      opacity: 0;
    }
    50% {
      transform: translateY(-120px) scale(1.5);
      opacity: 0.4;
    }
    100% {
      transform: translateY(-30px) scale(0);
      opacity: 0;
    }
  }

</style>

<script is:inline>
  function initAppleLoader() {
    const loader = document.getElementById("apple-loader");
    const progressBar = document.getElementById("loader-progress-bar");
    const loaderText = document.getElementById("loader-text");
    const loaderPercentage = document.getElementById("loader-percentage");
    const contentContainer = document.getElementById("loader-content-container");
    const appleLogoContainer = document.getElementById("apple-logo-container");
    const completionOverlay = document.getElementById("completion-overlay");
    const particlesContainer = document.getElementById("particles-container");

    if (!loader || !progressBar || !loaderText || !contentContainer) return;

    // Avoid running again on client-side navigation
    if (window.__loaderCompleted) {
      loader.style.display = "none";
      document.body.style.overflow = '';
      return;
    }

    // Lock scroll
    document.body.style.overflow = 'hidden';

    // Generate particles
    if (particlesContainer) {
      for (let i = 0; i < 20; i++) {
        const p = document.createElement("div");
        p.className = "particle";
        p.style.left = Math.random() * 100 + "%";
        p.style.top = Math.random() * 100 + "%";
        const duration = 8 + Math.random() * 4;
        const delay = Math.random() * 6;
        p.style.animationDuration = duration + "s";
        p.style.animationDelay = delay + "s";
        particlesContainer.appendChild(p);
      }
    }

    // Bootup logo animation
    setTimeout(() => {
      appleLogoContainer.classList.remove("opacity-0", "scale-50");
      appleLogoContainer.classList.add("opacity-100", "scale-100");
    }, 50);

    // Bootup progress section animation
    setTimeout(() => {
      contentContainer.classList.remove("opacity-0", "translate-y-[30px]");
      contentContainer.classList.add("opacity-100", "translate-y-0");
    }, 1000);

    const phases = [
      "Starting up...",
      "Loading system components...",
      "Initializing portfolio...",
      "Ready to innovate!"
    ];

    let progress = 0;
    let currentPhase = 0;
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function completeLoading() {
      // Fade out progress bar & text
      contentContainer.style.opacity = "0";
      setTimeout(() => {
        contentContainer.style.display = "none";
        
        // Directly transition into portfolio
        completionOverlay.classList.remove("opacity-0", "pointer-events-none");
        completionOverlay.classList.add("opacity-100");

        setTimeout(() => {
          window.__loaderCompleted = true;
          loader.style.opacity = "0";
          loader.style.pointerEvents = "none";
          document.body.style.overflow = ''; // Unlock scroll
          
          // Let it fade out, then hide it completely
          setTimeout(() => {
            loader.style.display = "none";
          }, 1000);
        }, 800);
      }, 500);
    }

    // If reduced motion, skip the animation
    if (prefersReducedMotion) {
      progress = 100;
      progressBar.style.width = "100%";
      loaderText.innerText = phases[phases.length - 1];
      loaderPercentage.innerText = "100%";
      setTimeout(completeLoading, 400); // Small delay to let initial animations finish
      return;
    }

    // Ensure it completes eventually even if progress interval fails
    const buttonTimer = setTimeout(() => {
      if (progress < 100) {
        progress = 100;
        progressBar.style.width = "100%";
        loaderText.innerText = phases[phases.length - 1];
        loaderPercentage.innerText = "100%";
        completeLoading();
      }
    }, 4000);

    const interval = setInterval(() => {
      const increment = Math.random() * 6 + 3; // 3-9%
      progress += increment;

      if (progress > 25 && currentPhase === 0) currentPhase = 1;
      if (progress > 60 && currentPhase === 1) currentPhase = 2;
      if (progress > 90 && currentPhase === 2) currentPhase = 3;

      if (progress >= 100) {
        progress = 100;
        clearInterval(interval);
        clearTimeout(buttonTimer);
        setTimeout(completeLoading, 400);
      }

      progressBar.style.width = `${progress}%`;
      // animate text change? simple change
      loaderText.innerText = phases[Math.min(currentPhase, phases.length - 1)];
      loaderPercentage.innerText = `${Math.round(progress)}%`;
    }, 200);
  }

  // Run on first load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAppleLoader);
  } else {
    initAppleLoader();
  }

  // Hide loader immediately on Astro client-side navigation
  document.addEventListener("astro:page-load", () => {
    const loader = document.getElementById("apple-loader");
    if (loader && window.__loaderCompleted) {
      loader.style.display = "none";
      loader.style.opacity = "0";
      document.body.style.overflow = '';
    }
  });
</script>
