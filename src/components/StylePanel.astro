---
const DOT = "w-1 h-1 rounded-full bg-current";
const BTN =
  "style-btn relative w-full h-9 flex items-center justify-center text-white/40 hover:text-white hover:bg-white/5 transition-all duration-200 outline-none";

const styles = [
  { id: "default", label: "Default", n: 1 },
  { id: "style-glass", label: "Glass", n: 2 },
  { id: "style-sharp", label: "Sharp", n: 3 },
  { id: "style-neon", label: "Neon", n: 4 },
  { id: "style-paper", label: "Paper", n: 5 },
];
---

<div
  class="style-btn-panel w-9 flex flex-col items-center rounded-lg bg-darkslate-500 border border-darkslate-400 shadow-lg overflow-hidden"
>
  <button
    id="style-panel-toggle"
    class="style-btn w-full h-9 flex items-center justify-center text-white/40 hover:text-white hover:bg-white/5 transition-all duration-200 outline-none"
    aria-label="Toggle style panel"
    title="Styles"
  >
    <svg
      id="style-icon-sliders"
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m9.06 11.9 8.07-8.06a2.85 2.85 0 1 1 4.03 4.03l-8.06 8.08"
      ></path>
      <path
        d="M7.07 14.94c-1.66 0-3 1.35-3 3.02 0 1.33-2.5 1.52-2 2.02 1.08 1.1 2.49 2.02 4 2.02 2.2 0 4-1.8 4-4.04a3.01 3.01 0 0 0-3-3.02z"
      ></path>
    </svg>
    <svg
      id="style-icon-arrow"
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="hidden"
    >
      <polyline points="6,9 12,15 18,9"></polyline>
    </svg>
  </button>

  <div
    id="style-btn-list"
    class="w-full overflow-hidden"
    style="max-height:0;transition:max-height 250ms ease"
  >
    <div class="w-full h-px bg-white/5"></div>
    {
      styles.map(({ id, label, n }) => (
        <button
          class={BTN}
          data-style={id}
          aria-label={`${label} style`}
          title={label}
        >
          {n === 1 && <span class={DOT} />}
          {n === 2 && (
            <span class="flex gap-1">
              <span class={DOT} />
              <span class={DOT} />
            </span>
          )}
          {n === 3 && (
            <span class="flex flex-col items-center gap-1">
              <span class={DOT} />
              <span class="flex gap-1">
                <span class={DOT} />
                <span class={DOT} />
              </span>
            </span>
          )}
          {n === 4 && (
            <span class="grid grid-cols-2 gap-1">
              <span class={DOT} />
              <span class={DOT} />
              <span class={DOT} />
              <span class={DOT} />
            </span>
          )}
          {n === 5 && (
            <span class="grid grid-cols-3 gap-0.5">
              <span class={DOT} />
              <span />
              <span class={DOT} />
              <span />
              <span class={DOT} />
              <span />
              <span class={DOT} />
              <span />
              <span class={DOT} />
            </span>
          )}
          <span class="absolute top-1 right-1.5 text-[7px] opacity-40 leading-none">
            {n}
          </span>
        </button>
      ))
    }
  </div>
</div>

<script>
  const ALL_STYLES = [
    "style-glass",
    "style-sharp",
    "style-neon",
    "style-paper",
  ];

  function playStyleSound() {
    if (localStorage.getItem("soundEnabled") === "false") return;
    const ctx = new AudioContext();
    [440, 554, 659].forEach((freq, i) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.type = "triangle";
      osc.frequency.value = freq;
      const t = ctx.currentTime + i * 0.055;
      gain.gain.setValueAtTime(0.0, t);
      gain.gain.linearRampToValueAtTime(0.09, t + 0.01);
      gain.gain.exponentialRampToValueAtTime(0.001, t + 0.18);
      osc.start(t);
      osc.stop(t + 0.18);
    });
  }

  function updateStyleBtns() {
    const current = localStorage.getItem("portfolioStyle") || "default";
    document.querySelectorAll<HTMLElement>(".style-btn").forEach((btn) => {
      const active = btn.dataset.style === current;
      btn.classList.toggle("text-white", active);
      btn.classList.toggle("text-white/50", !active);
      btn.classList.toggle("bg-white/10", active);
    });
  }

  function setPanelOpen(open: boolean) {
    const list = document.getElementById("style-btn-list");
    const iconSliders = document.getElementById("style-icon-sliders");
    const iconArrow = document.getElementById("style-icon-arrow");
    if (list) list.style.maxHeight = open ? "360px" : "0";
    iconSliders?.classList.toggle("hidden", open);
    iconArrow?.classList.toggle("hidden", !open);
    localStorage.setItem("stylePanelOpen", String(open));
  }

  function initStylePanel() {
    const savedStyle = localStorage.getItem("portfolioStyle");
    if (savedStyle && savedStyle !== "default")
      document.body.classList.add(savedStyle);

    updateStyleBtns();
    setPanelOpen(false);

    document.querySelectorAll<HTMLElement>(".style-btn").forEach((btn) => {
      // Clone elements to clear old event listeners
      const newBtn = btn.cloneNode(true) as HTMLElement;
      btn.parentNode?.replaceChild(newBtn, btn);

      if (newBtn.id === "style-panel-toggle") {
        newBtn.addEventListener("click", () => {
          const list = document.getElementById("style-btn-list");
          const isOpen =
            list?.style.maxHeight !== "0px" && list?.style.maxHeight !== "0";
          setPanelOpen(!isOpen);
        });
      } else {
        newBtn.addEventListener("click", () => {
          const style = newBtn.dataset.style as string;
          document.body.classList.remove(...ALL_STYLES);
          localStorage.setItem("portfolioStyle", style);
          if (style !== "default") document.body.classList.add(style);
          updateStyleBtns();
          playStyleSound();
        });
      }
    });
  }

  // Run immediately on script execution
  initStylePanel();

  // Run on page-load event
  document.addEventListener("astro:page-load", initStylePanel);
</script>
