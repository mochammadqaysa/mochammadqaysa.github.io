---
import Layout from "../layouts/Layout.astro";
import LoaderAnimation from "../components/LoaderAnimation.astro";
import BackLink from "../components/BackLink.astro";
import { SITE } from "../site-config";
import TiaraIcon from "../assets/projects/icons/inventory_tip.png";
import DakIcon from "../assets/projects/icons/dak.png";

const experiences = [
  {
    company: "PT. Tiara Indoprima",
    location: "Bandung, Indonesia",
    companyPeriod: "Sep 2024 – Present",
    icon: TiaraIcon,
    roles: [
      {
        title: "Staff IT & Logistik",
        period: "Sep 2024 – Present",
        type: "Full-time",
        tags: ["Laravel", "PHP", "MySQL", "Export-Import", "Logistics"],
        responsibilities: [
          "Developed internal Laravel-based inventory system for export-import reporting (TIP - IT Inventory).",
          "Handled export-import operations and customs documentation for submission to DJBC (Directorate General of Customs).",
          "Coordinated logistics operations and ensured compliance with export-import regulations.",
          "Maintained and monitored internal IT infrastructure and provided technical support.",
        ],
      },
    ],
  },
  {
    company: "PT. Digital Amore Kriyanesia",
    location: "Bandung, Indonesia",
    companyPeriod: "Oct 2021 – Aug 2024",
    icon: DakIcon,
    roles: [
      {
        title: "Full Stack Developer",
        period: "Oct 2021 – Aug 2024",
        type: "Full-time",
        tags: ["Laravel", "PHP", "JavaScript", "MySQL"],
        responsibilities: [
          "Developed full-stack web applications for client projects including Molect PODI Web and Molect MSA Web.",
          "Built RESTful APIs and integrated them with both mobile and web frontends.",
          "Managed database design, server-side logic, and client-side interactions.",
        ],
      },
      {
        title: "Mobile Developer (Native & Flutter)",
        period: "Jan 2022 – Aug 2024",
        type: "Full-time",
        tags: ["Flutter", "Dart", "Kotlin", "Swift", "SwiftUI", "Android", "iOS"],
        responsibilities: [
          "Built cross-platform mobile apps using Flutter (Dart) for Android and iOS platforms.",
          "Developed native Android apps using Kotlin with MVVM architecture.",
          "Integrated Bluetooth ESC/POS thermal printer and GPS geolocation features.",
          "Delivered: Molect MSA Mobile, Molect PODI Mobile, BPDDIY Raharjo, Digdaya Authenticator.",
        ],
      },
      {
        title: "Back End Developer",
        period: "Jan 2022 – Aug 2024",
        type: "Full-time",
        tags: ["Java", "Spring Boot", "REST API"],
        responsibilities: [
          "Developed RESTful backend services using Java and Spring Boot.",
          "Designed and maintained scalable API architecture for mobile and web client consumption.",
          "Implemented authentication, data processing, and business logic layers.",
        ],
      },
    ],
  },
  {
    company: "Freelance",
    location: "Remote",
    companyPeriod: "2021 – Present",
    roles: [
      {
        title: "Freelance Developer",
        period: "2021 – Present",
        type: "Freelance",
        tags: ["Laravel", "PHP", "Flutter", "Dart", "MySQL"],
        responsibilities: [
          "Layung Peradilan (2025) – Public court information system for PN Bale Bandung, built with Laravel.",
          "Kretek Asli Bandung (2025) – Massage parlor scheduling & booking system (client + admin side) with Laravel.",
          "Dago Valley Explore (2025) – Cross-platform tourism app running on Windows, Web, Android TV, and Samsung Tizen, built with Flutter.",
        ],
      },
    ],
  },
];
---

<LoaderAnimation />

<Layout
  title={`${SITE.author.fullName} - Experience`}
  description="Professional work experience and career history of Mochammad Qaysa Al Haq."
>
  <main
    class="w-screen flex flex-col justify-start items-start max-w-3xl mx-auto p-8 text-white pb-20"
  >
    <BackLink href="/" class="mb-8" />

    <div class="mb-10">
      <h1 class="text-4xl font-bold text-neutral-100">Experience</h1>
      <p class="text-darkslate-300 text-sm mt-2">
        My professional journey as a software developer.
      </p>
    </div>

    <!-- Timeline -->
    <div class="timeline w-full relative">
      <!-- Vertical line -->
      <div class="timeline-line"></div>

      {
        experiences.map((exp, i) => (
          <div class="timeline-item group" style={`--delay: ${i * 90}ms`}>
            <!-- Dot -->
            <div class="timeline-dot">
              <div class="timeline-dot-inner" />
            </div>

            <!-- Card -->
            <div class="timeline-card card">

              <!-- Company header -->
              <div class="company-header">
                <div class="flex items-center justify-between gap-2 flex-wrap">
                  <div class="flex items-center gap-2">
                    {exp.icon ? (
                      <img
                        src={exp.icon.src}
                        alt={exp.company}
                        class="company-icon"
                      />
                    ) : (
                      <svg class="w-3.5 h-3.5 flex-shrink-0 text-primary-400" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4zm3 1h6v4H7V5zm6 6H7v2h6v-2z" clip-rule="evenodd" />
                      </svg>
                    )}
                    <span class="text-sm font-semibold text-primary-400">{exp.company}</span>
                    <span class="text-darkslate-400 text-xs">·</span>
                    <span class="text-darkslate-400 text-xs">{exp.location}</span>
                  </div>
                  <span class="text-[10px] text-darkslate-400 tabular-nums tracking-wider">{exp.companyPeriod}</span>
                </div>
              </div>

              <!-- Roles -->
              {exp.roles.map((role, ri) => (
                <div class={`role-block ${ri > 0 ? "role-divider" : ""}`}>
                  <!-- Role title & period -->
                  <div class="flex items-start justify-between gap-2 flex-wrap mb-2.5">
                    <div class="flex items-center gap-2">
                      <h2 class="text-[15px] font-semibold text-darkslate-50 leading-snug">
                        {role.title}
                      </h2>
                      <span class="exp-badge">{role.type}</span>
                    </div>
                    <span class="text-[10px] text-darkslate-400 tabular-nums tracking-wider whitespace-nowrap">
                      {role.period}
                    </span>
                  </div>

                  <!-- Responsibilities -->
                  <ul class="exp-list">
                    {role.responsibilities.map((item) => (
                      <li>
                        <span class="exp-bullet" />
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>

                  <!-- Tags -->
                  <div class="flex flex-wrap gap-1.5 mt-3">
                    {role.tags.map((tag) => (
                      <span class="exp-tag">{tag}</span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </main>
</Layout>

<style>
  /* ── Timeline layout ── */
  .timeline {
    padding-left: 28px;
  }

  .timeline-line {
    position: absolute;
    left: 6px;
    top: 8px;
    bottom: 0;
    width: 1.5px;
    background: linear-gradient(
      to bottom,
      var(--primary-500),
      color-mix(in srgb, var(--primary-500) 20%, transparent)
    );
  }

  .timeline-item {
    position: relative;
    margin-bottom: 2rem;
    animation: slide-in 0.45s ease-out both;
    animation-delay: var(--delay, 0ms);
  }

  .timeline-item:last-child {
    margin-bottom: 0;
  }

  @keyframes slide-in {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Dot ── */
  .timeline-dot {
    position: absolute;
    left: -28px;
    top: 14px;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--darkslate-500, #171717);
    border: 1.5px solid var(--primary-500, #e63946);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s ease;
  }

  .timeline-dot-inner {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--primary-500, #e63946);
    transition: transform 0.2s ease;
  }

  .timeline-item:hover .timeline-dot {
    border-color: var(--primary-400);
  }

  .timeline-item:hover .timeline-dot-inner {
    transform: scale(1.3);
  }

  /* ── Card ── */
  .timeline-card {
    background: var(--darkslate-500, #171717);
    border: 1px solid var(--darkslate-400, #383838);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .timeline-item:hover .timeline-card {
    border-color: color-mix(in srgb, var(--primary-500) 40%, transparent);
    box-shadow: 0 4px 24px
      color-mix(in srgb, var(--primary-500) 8%, transparent);
  }

  /* ── Badge ── */
  .exp-badge {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--primary-500) 12%, transparent);
    color: var(--primary-400, #e64f59);
    border: 1px solid color-mix(in srgb, var(--primary-500) 30%, transparent);
  }

  /* ── Responsibility list ── */
  .exp-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .exp-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--darkslate-300, #9a9a9a);
  }

  .exp-bullet {
    flex-shrink: 0;
    margin-top: 0.45em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--primary-500, #e63946);
    opacity: 0.7;
  }

  /* ── Tech tags ── */
  .exp-tag {
    font-size: 10px;
    font-weight: 500;
    padding: 2px 10px;
    border-radius: 999px;
    border: 1px solid var(--darkslate-400, #383838);
    color: var(--darkslate-300, #9a9a9a);
    transition: border-color 0.2s ease;
  }

  .timeline-item:hover .exp-tag {
    border-color: var(--darkslate-200, #c9c9c9);
  }

  /* ── Company header ── */
  .company-header {
    padding-bottom: 0.75rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px solid var(--darkslate-400, #383838);
  }

  /* ── Role block ── */
  .role-block {
    padding-top: 0.75rem;
  }

  .role-block:first-of-type {
    padding-top: 0;
  }

  .role-divider {
    border-top: 1px dashed color-mix(in srgb, var(--darkslate-400) 60%, transparent);
    margin-top: 0.75rem;
  }
  /* ── Company icon ── */
  .company-icon {
    width: 28px;
    height: 28px;
    min-width: 28px;
    min-height: 28px;
    max-width: 28px;
    max-height: 28px;
    border-radius: 6px;
    object-fit: contain;
    background: var(--darkslate-600, #141414);
    border: 1px solid var(--darkslate-400, #383838);
    padding: 2px;
    flex-shrink: 0;
  }
</style>
