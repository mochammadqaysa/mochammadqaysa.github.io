---
import Layout from "../layouts/Layout.astro";
import BackLink from "../components/BackLink.astro";
import { SITE } from "../site-config";
import { collection, getDocs, query, orderBy } from "firebase/firestore";
import { db } from "../firebase";
import GuestbookCard from "../components/guestbook/GuestbookCard.astro";
import GuestbookForm from "../components/guestbook/GuestbookForm.astro";
import GuestbookPagination from "../components/guestbook/GuestbookPagination.astro";
import { ENTRIES_PER_PAGE, type GuestbookEntry } from "../lib/guestbook";

const requestedPage = Math.max(
  1,
  parseInt(Astro.url.searchParams.get("page") ?? "1", 10),
);

Astro.response.headers.set(
  "Cache-Control",
  "private, max-age=0, must-revalidate",
);

const q = query(collection(db, "messages"), orderBy("createdAt", "desc"));
const snapshot = await getDocs(q);

const allEntries: GuestbookEntry[] = snapshot.docs.map((doc: any) => {
  const data = doc.data();
  const createdAt = data.createdAt?.toDate
    ? data.createdAt.toDate().toISOString()
    : new Date().toISOString();

  return {
    id: doc.id,
    text: data.text || "",
    uid: data.uid || "",
    displayName: data.displayName || "Unknown",
    photoURL: data.photoURL || null,
    createdAt,
  };
});

const totalEntries = allEntries.length;
const totalPages = Math.max(1, Math.ceil(totalEntries / ENTRIES_PER_PAGE));

const entries = allEntries.slice(
  (requestedPage - 1) * ENTRIES_PER_PAGE,
  requestedPage * ENTRIES_PER_PAGE
);
---

<Layout
  title={`${SITE.author.fullName} - Guestbook`}
  description="Leave a message in my guestbook"
  hideCal={true}
>
  <div class="flex flex-col items-center px-4 pt-36 pb-24">
    <BackLink href="/" class="fixed top-10 left-10 z-50 text-sm" />

    <header class="w-full max-w-xl mb-12 text-center">
      <h1 class="text-white text-3xl font-bold tracking-tight mb-3">
        Guestbook
      </h1>
      <p class="text-darkslate-300 text-sm leading-relaxed">
        Drop a note, say hi, or share your thoughts. I read every message.
      </p>
    </header>

    <GuestbookForm class="w-full max-w-xl mb-12" />

    <section class="w-full max-w-3xl">
      <h2 id="entries-count" class="text-white text-sm font-semibold mb-4">
        {totalEntries} messages
      </h2>

      <div id="entries" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {
          entries.length === 0 ? (
            <p
              data-empty-state
              class="col-span-2 text-center py-20 text-darkslate-300 text-sm"
            >
              No messages yet — be the first to leave one.
            </p>
          ) : (
            entries.map((entry) => <GuestbookCard entry={entry} />)
          )
        }
      </div>

      <GuestbookPagination
        currentPage={requestedPage}
        totalPages={totalPages}
      />
    </section>
  </div>
</Layout>
