---
import { getEntry, render } from "astro:content";
import { getCollection } from "astro:content";
import LayoutBlogPost from "../../layouts/LayoutBlogPost.astro";
import { SITE } from "../../site-config";

export const prerender = true;

export async function getStaticPaths() {
  return (await getCollection("blog")).map(({ id }) => ({
    params: { id: id as string },
  }));
}

const { id } = Astro.params;

if (!id) {
  throw new Error("id is missing");
}

const entry = await getEntry("blog", id);

if (!entry) {
  return Astro.redirect("/404");
}

const { Content, remarkPluginFrontmatter } = await render(entry);

const ogImage = entry.data.ogImage ?? "/blog/arcade1.jpg";
const keywords = entry.data.keywords;
const heroImages = entry.data.heroImages ?? [];
const tags = entry.data.tags ?? [];
---

<LayoutBlogPost
  description={entry.data.description!}
  minutesRead={remarkPluginFrontmatter.minutesRead}
  pubDate={entry.data.pubDate!}
  title={`${entry.data.title} | ${SITE.author.fullName}`}
  url={`blog/${entry.id}`}
  ogImage={ogImage}
  keywords={keywords}
  heroImages={heroImages}
  tags={tags}
>
  <Content />
</LayoutBlogPost>
