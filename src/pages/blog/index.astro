---
import Layout from "../../layouts/Layout.astro";
import LoaderAnimation from "../../components/LoaderAnimation.astro";
import BackLink from "../../components/BackLink.astro";
import { SITE } from "../../site-config";
import { getCollection } from "astro:content";
import { formatDate } from "../../lib/helpers";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort(
    (a, b) =>
      new Date(b.data.pubDate!).getTime() - new Date(a.data.pubDate!).getTime(),
  );
---

<LoaderAnimation />

<Layout
  description="Software developer with strong focus on the user experience animations and micro interactions"
  title={`${SITE.author.fullName} - Blog`}
>
  <main
    class="w-screen min-h-screen flex flex-col justify-start items-start max-w-3xl mx-auto p-8"
  >
    <BackLink href="/" class="mb-8" />
    <h1 class="text-4xl font-bold mb-2 text-neutral-100">Posts</h1>
    <p class="text-darkslate-400 text-sm mb-10">
      Thoughts, notes, and things I find worth sharing.
    </p>

    {
      posts.length === 0 ? (
        <p class="text-darkslate-300 text-sm">
          Nothing to say right now... check back later (or don't, no pressure
          🙃)
        </p>
      ) : (
        <ul class="w-full flex flex-col gap-6">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}`}
                class="group flex flex-col gap-1 p-5 rounded-xl border border-darkslate-700 hover:border-darkslate-500 bg-darkslate-800 hover:bg-darkslate-700 transition-all duration-200"
              >
                <span class="text-xs text-darkslate-400 uppercase tracking-widest">
                  {post.data.category ?? "general"} ·{" "}
                  {formatDate(post.data.pubDate!)}
                </span>
                <h2 class="text-neutral-100 font-semibold text-lg group-hover:text-white transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-darkslate-300 text-sm line-clamp-2">
                  {post.data.description}
                </p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-3">
                    {post.data.tags.map((tag) => (
                      <span class="text-[11px] px-2 py-0.5 rounded-full border border-darkslate-400 text-darkslate-100 hover:border-primary-500 hover:text-white transition-colors duration-150 cursor-default">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                <span class="mt-2 text-xs text-darkslate-400 group-hover:text-neutral-300 transition-colors">
                  Read more →
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</Layout>
