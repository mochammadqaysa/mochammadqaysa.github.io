---
import Card from "../../components/Card/index.astro";
import LoaderAnimation from "../../components/LoaderAnimation.astro";
import BackLink from "../../components/BackLink.astro";
import Layout from "../../layouts/Layout.astro";
import { SITE } from "../../site-config";
import { getCollection } from "astro:content";
import { formatDate } from "../../lib/helpers";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort(
    (a, b) =>
      new Date(b.data.pubDate!).getTime() - new Date(a.data.pubDate!).getTime(),
  );
---

<LoaderAnimation />

<Layout
  description="Software developer with strong focus on the user experience animations and micro interactions"
  title={`${SITE.author.fullName} - Blog`}
>
  <main
    class="w-screen min-h-screen flex flex-col justify-start items-start max-w-3xl mx-auto p-8"
  >
    <BackLink href="/" class="mb-8" />
    <h1 class="text-4xl font-bold mb-2 text-neutral-100">Posts</h1>
    <p class="text-darkslate-400 text-sm mb-10">
      Thoughts, notes, and things I find worth sharing.
    </p>

    {
      posts.length === 0 ? (
        <p class="text-darkslate-300 text-sm">
          Nothing to say right now... check back later (or don't, no pressure
          🙃)
        </p>
      ) : (
        <ul class="w-full flex flex-col gap-4">
          {posts.map((post) => (
            <li>
              <Card href={`/blog/${post.id}`} colSpan="col-span-1" arrowCorner>
                <div class="flex flex-col gap-2 w-full pr-6">
                  <span class="text-[11px] text-darkslate-300 uppercase tracking-widest">
                    {post.data.category ?? "general"} ·{" "}
                    {formatDate(post.data.pubDate!)}
                  </span>
                  <h2 class="text-neutral-100 font-semibold text-base leading-snug m-0 group-hover:text-white transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="text-darkslate-300 text-sm line-clamp-2 font-light m-0">
                    {post.data.description}
                  </p>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mt-1">
                      {post.data.tags.map((tag) => (
                        <span class="text-[10px] px-2 py-0.5 rounded-full border border-darkslate-400 text-darkslate-100 group-hover:border-primary-500 transition-colors duration-150 cursor-default">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </Card>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</Layout>
